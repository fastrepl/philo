---
import { siteConfig, } from "../lib/site";
import SiteLayout from "./SiteLayout.astro";

interface Props {
  title: string;
  description: string;
  path: string;
  label: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, path, label, schema, } = Astro.props;
---

<SiteLayout title={title} description={description} path={path} schema={schema}>
  <main class="collection-shell">
    <header class="page-header">
      <a class="back-link" href="/">← Back to Philo</a>
      <p class="eyebrow">{label}</p>
      <h1>{title}</h1>
      <p class="summary">{description}</p>
    </header>

    <slot />

    <footer class="footer">
      <nav>
        <a href="/blog">Blog</a>
        <a href="/guides">Guides</a>
        <a href="/use-cases">Use cases</a>
        <a href="/comparisons">Comparisons</a>
        <a href="/glossary">Glossary</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a href={siteConfig.repoUrl}>GitHub</a>
        <a href={`mailto:${siteConfig.email}`}>Email</a>
      </nav>
    </footer>
  </main>
</SiteLayout>

<style>
  .collection-shell {
    position: relative;
    width: min(100%, 780px);
    margin: 0 auto;
    padding: 56px 24px 88px;
  }

  .page-header {
    border-bottom: 1px solid var(--line);
    padding-bottom: 18px;
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .back-link:hover,
  .footer a:hover {
    text-decoration: underline;
  }

  .eyebrow {
    margin: 20px 0 0;
    color: #3f3f3d;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    margin: 12px 0 0;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.45;
  }

  .summary {
    margin: 10px 0 0;
    color: #3f3f3d;
    font-size: 15px;
    line-height: 1.72;
  }

  .footer {
    margin-top: 32px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }

  .footer nav {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer a {
    color: var(--accent);
    text-decoration: none;
  }

  @media (max-width: 720px) {
    .collection-shell {
      padding: 40px 18px 62px;
    }
  }
</style>
