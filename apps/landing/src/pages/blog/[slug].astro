---
import { getCollection, render, } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog",);
  return posts.map((post,) => ({
    params: { slug: post.slug, },
    props: { post, },
  }));
}

const { post, } = Astro.props;
const { Content, } = await render(post,);

const publishedLabel = post.data.publishedAt.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
},);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} | Philo</title>
    <meta name="description" content={post.data.summary} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient"></div>
    <main class="shell">
      <header class="post-header">
        <a class="back-link" href="/">← Back to Philo</a>
        <p class="label">Notes from the team</p>
        <h1>{post.data.title}</h1>
        <p class="meta">{publishedLabel}</p>
        <p class="summary">{post.data.summary}</p>
      </header>

      <article class="post-content">
        <Content />
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f4f4f1;
    --bg-soft: #f8f8f6;
    --line: #e2e2db;
    --text: #252525;
    --muted: #646460;
    --accent: #5f70d8;
    --fs-xs: 11px;
    --fs-sm: 12px;
    --fs-md: 13px;
    --fs-lg: 14px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-weight: 400;
    font-size: var(--fs-md);
    line-height: 1.6;
    background: linear-gradient(150deg, #f6f6f4 0%, #efefeb 100%);
    color: var(--text);
    position: relative;
  }

  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 5% 8%, #ffffff 0%, transparent 32%),
      radial-gradient(circle at 92% 92%, #e8ebff 0%, transparent 38%);
    opacity: 0.8;
  }

  .shell {
    position: relative;
    width: min(100%, 720px);
    margin: 0 auto;
    padding: 56px 24px 88px;
  }

  .back-link {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .post-header {
    border-bottom: 1px solid var(--line);
    padding-bottom: 18px;
  }

  .label {
    margin: 20px 0 0;
    color: #3f3f3d;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  h1 {
    margin: 12px 0 0;
    font-size: var(--fs-lg);
    font-weight: 500;
    line-height: 1.6;
  }

  .meta {
    margin: 8px 0 0;
    color: #6b6b66;
    font-size: var(--fs-sm);
  }

  .summary {
    margin: 10px 0 0;
    color: #3f3f3d;
    font-size: var(--fs-md);
  }

  .post-content {
    margin-top: 22px;
    color: var(--muted);
  }

  .post-content :global(h2) {
    margin: 24px 0 6px;
    color: var(--text);
    font-size: var(--fs-md);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .post-content :global(p) {
    margin: 10px 0;
    color: var(--muted);
    font-size: var(--fs-md);
    line-height: 1.7;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 10px 0;
    padding-left: 18px;
  }

  .post-content :global(ol) {
    list-style: none;
    counter-reset: ol-counter;
    padding-left: 0;
  }

  .post-content :global(ol) > :global(li) {
    counter-increment: ol-counter;
  }

  .post-content :global(ol) > :global(li)::before {
    content: counter(ol-counter) ".\00a0";
  }

  .post-content :global(li) {
    margin: 6px 0;
    font-size: var(--fs-md);
    color: var(--muted);
  }

  .post-content :global(code) {
    background: color-mix(in srgb, var(--bg-soft) 80%, #ffffff);
    border: 1px solid var(--line);
    padding: 1px 4px;
    font-size: var(--fs-sm);
  }

  @media (max-width: 720px) {
    .shell {
      padding: 40px 18px 62px;
    }
  }
</style>
