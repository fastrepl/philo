    color: var(--muted);
    font-size: 13px;
    line-height: 1.72;
  }

  .download-split {
    position: relative;
    display: inline-flex;
    margin-top: 14px;
  }

  .download-button {
    color: var(--accent);
    font-family: inherit;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    background: color-mix(in srgb, var(--accent) 8%, #ffffff);
    padding: 8px 10px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .platform-icon-set {
    width: 14px;
    height: 14px;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
  }

  .platform-icon {
    width: 14px;
    height: 14px;
    display: block;
    flex: 0 0 auto;
  }

  .platform-icon[data-download-primary-icon="macos"],
  .download-menu [data-download-macos] .platform-icon {
    transform: translateY(-1px);
  }

  .platform-icon-set .platform-icon {
    grid-area: 1 / 1;
    display: none;
  }

  .platform-icon-set .platform-icon.is-active {
    display: block;
  }

  .brand-beta {
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    background: color-mix(in srgb, var(--accent) 12%, #ffffff);
    color: var(--accent);
    padding: 2px 5px;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1;
    vertical-align: middle;
    position: relative;
    top: -1px;
  }

  .download-button:hover {
    border-color: color-mix(in srgb, var(--accent) 44%, var(--line));
    background: color-mix(in srgb, var(--accent) 14%, #ffffff);
  }

  .download-chevron {
    font-family: inherit;
    font-size: var(--fs-sm);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    border-left: 0;
    background: color-mix(in srgb, var(--accent) 8%, #ffffff);
    padding: 0 8px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
  }

  .download-chevron:hover {
    border-color: color-mix(in srgb, var(--accent) 44%, var(--line));
    background: color-mix(in srgb, var(--accent) 14%, #ffffff);
  }

  .download-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 4px;
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    background: #ffffff;
    z-index: 10;
  }

  .download-menu.is-open {
    display: flex;
    flex-direction: column;
  }

  .download-menu a,
  .download-menu a:visited {
    padding: 8px 10px;
    color: var(--text);
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .download-menu a:hover {
    background: color-mix(in srgb, var(--accent) 8%, #ffffff);
    color: var(--accent);
  }

  .download-menu a.is-current {
    display: none;
  }

  .hero-media-mobile {
    display: none;
    margin-top: 18px;
  }

  .panel {
    margin-top: 46px;
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }

  h2 {
    margin: 0;
    color: #3f3f3d;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .detail-list,
  .link-list {
    list-style: none;
    padding: 0;
    margin: 16px 0 0;
  }

  .detail-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .detail-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 16px;
    align-items: start;
  }

  .detail-visual {
    inline-size: 220px;
    block-size: 78px;
    border: 1px dashed color-mix(in srgb, var(--line) 82%, #bfc2ce);
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.9) 0%, transparent 42%),
      color-mix(in srgb, var(--bg-soft) 90%, #ffffff);
    padding: 8px;
    overflow: hidden;
    display: grid;
    align-items: center;
  }

  .mini-timeline,
  .mini-rollover,
  .mini-recurring,
  .mini-markdown-apps,
  .mini-open-source {
    width: 100%;
    height: 100%;
  }

  .mini-timeline {
    --mini-timeline-day-height: 44px;
    --mini-timeline-gap: 6px;
    --mini-timeline-step: calc(var(--mini-timeline-day-height) + var(--mini-timeline-gap));
    position: relative;
    overflow: hidden;
  }

  .mini-timeline-track {
    display: grid;
    gap: var(--mini-timeline-gap);
    animation: mini-timeline-scroll 6s ease-in-out infinite;
  }

  .mini-timeline-day,
  .mini-rollover-column {
    border: 1px solid color-mix(in srgb, var(--line) 80%, #d3d6df);
    background: rgba(255, 255, 255, 0.9);
    padding: 4px;
    display: grid;
    gap: 4px;
    position: relative;
  }

  .mini-timeline-day {
    block-size: var(--mini-timeline-day-height);
    align-content: start;
  }

  .mini-timeline-day p,
  .mini-rollover-column p,
  .mini-stars-label,
  .mini-stars-value {
    margin: 0;
  }

  .mini-timeline-day p,
  .mini-rollover-column p {
    color: #454540;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .mini-skeleton {
    display: block;
    height: 5px;
    border: 1px solid color-mix(in srgb, var(--line) 80%, #d1d4de);
    background: rgba(95, 95, 90, 0.08);
  }

  .mini-skeleton-short {
    width: 56%;
  }

  .mini-skeleton-fade {
    display: none;
  }

  .mini-rollover {
    position: relative;
  }

  .mini-rollover-columns {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 6px;
  }

  .mini-rollover-source {
    animation: mini-rollover-source-focus 5s ease-in-out infinite;
  }

  .mini-rollover-target {
    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
    animation: mini-rollover-target-focus 5s ease-in-out infinite;
  }

  .mini-task-row,
  .mini-recurring-task {
    display: grid;
    grid-template-columns: 8px minmax(0, 1fr);
    gap: 5px;
    align-items: center;
  }

  .mini-task-row-fading {
    animation: mini-source-task-fade 5s ease-in-out infinite;
  }

  .mini-task-row-fading-delay {
    animation-delay: 0.25s;
  }

  .mini-checkbox {
    display: block;
    width: 8px;
    height: 8px;
    border: 1px solid color-mix(in srgb, var(--line) 80%, #bfc2ce);
    background: #ffffff;
    position: relative;
  }

  .mini-checkbox.is-checked {
    background: color-mix(in srgb, var(--accent) 16%, #ffffff);
    border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
  }

  .mini-checkbox.is-checked::after {
    content: "";
    position: absolute;
    left: 1px;
    top: -1px;
    width: 3px;
    height: 6px;
    border-right: 1.5px solid var(--accent);
    border-bottom: 1.5px solid var(--accent);
    transform: rotate(40deg);
  }

  .mini-task-bar {
    display: block;
    height: 6px;
    border: 1px solid color-mix(in srgb, var(--line) 80%, #d1d4de);
    background: #f6f6f3;
  }

  .mini-task-bar-wide {
    width: 86%;
  }

  .mini-task-bar-short {
    width: 62%;
  }

  .mini-today-pill {
    position: absolute;
    top: 4px;
    right: 4px;
    padding: 0 4px;
    border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--line));
    background: color-mix(in srgb, var(--accent) 10%, #ffffff);
    color: var(--accent);
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .mini-today-pill-source {
    animation: mini-today-source-fade 5s ease-in-out infinite;
  }

  .mini-today-pill-target {
    opacity: 0;
    animation: mini-today-target-fade 5s ease-in-out infinite;
  }

  .mini-moving-task {
    position: absolute;
    left: 40%;
    width: 34px;
    height: 6px;
    border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--line));
    background: color-mix(in srgb, var(--accent) 12%, #ffffff);
    opacity: 0;
  }

  .mini-moving-task-first {
    top: 28px;
    animation: mini-rollover-move 5s ease-in-out infinite;
  }

  .mini-moving-task-second {
    top: 44px;
    width: 26px;
    animation: mini-rollover-move 5s ease-in-out infinite 0.25s;
  }

  .mini-recurring {
    display: flex;
    align-items: center;
  }

  .mini-recurring-task {
    width: 100%;
    grid-template-columns: 8px minmax(0, 1fr) auto;
    border: 1px solid color-mix(in srgb, var(--line) 80%, #d3d6df);
    background: rgba(255, 255, 255, 0.9);
    padding: 6px;
  }

  .mini-frequency-chip {
    padding: 1px 5px;
    border: 1px solid color-mix(in srgb, var(--accent) 34%, var(--line));
    background: color-mix(in srgb, var(--accent) 10%, #ffffff);
    color: var(--accent);
    font-size: 8px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mini-markdown-apps {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .mini-app-icon {
    width: 30px;
    height: 30px;
    border: 1px solid color-mix(in srgb, var(--line) 80%, #d3d6df);
    background: rgba(255, 255, 255, 0.9);
    display: grid;
    place-items: center;
  }

  .mini-app-icon svg {
    width: 18px;
    height: 18px;
    display: block;
  }

  .mini-app-icon-markdown {
    color: #3f3f3d;
  }

  .mini-open-source {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    gap: 8px;
    align-items: center;
    height: 100%;
  }

  .mini-github-icon {
    width: 30px;
    height: 30px;
    border: 1px solid color-mix(in srgb, var(--line) 80%, #d3d6df);
    background: rgba(255, 255, 255, 0.92);
    color: #252525;
    display: grid;
    place-items: center;
  }

  .mini-github-icon svg {
    width: 16px;
    height: 16px;
  }

  .mini-stars {
    display: grid;
    gap: 4px;
  }

  .mini-stars-label {
    color: #676762;
    font-size: 8px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .mini-stars-value {
    color: #3f3f3d;
    font-size: 11px;
    font-weight: 500;
  }

  @keyframes mini-timeline-scroll {
    0%,
    18% {
      transform: translateY(0);
    }

    28%,
    46% {
      transform: translateY(calc(-1 * var(--mini-timeline-step)));
    }

    56%,
    74% {
      transform: translateY(calc(-2 * var(--mini-timeline-step)));
    }

    84%,
    100% {
      transform: translateY(calc(-2 * var(--mini-timeline-step)));
    }
  }

  @keyframes mini-rollover-source-focus {
    0%,
    48% {
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 34%, var(--line));
    }

    55%,
    100% {
      box-shadow: inset 0 0 0 1px transparent;
    }
  }

  @keyframes mini-rollover-target-focus {
    0%,
    48% {
      box-shadow: inset 0 0 0 1px transparent;
    }

    55%,
    100% {
      box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 34%, var(--line));
    }
  }

  @keyframes mini-today-source-fade {
    0%,
    45% {
      opacity: 1;
    }

    55%,
    100% {
      opacity: 0;
    }
  }

  @keyframes mini-today-target-fade {
    0%,
    45% {
      opacity: 0;
    }

    55%,
    100% {
      opacity: 1;
    }
  }

  @keyframes mini-rollover-move {
    0%,
    38% {
      opacity: 0;
      transform: translateX(-40px);
    }

    45%,
    72% {
      opacity: 1;
      transform: translateX(10px);
    }

    80%,
    100% {
      opacity: 0;
      transform: translateX(34px);
    }
  }

  @keyframes mini-source-task-fade {
    0%,
    40% {
      opacity: 1;
    }

    55%,
    100% {
      opacity: 0.28;
    }
  }

  .item-title {
    margin: 0;
    font-size: var(--fs-lg);
    font-weight: 500;
  }

  .link-list span {
    color: var(--accent);
  }

  .item-copy {
    margin: 6px 0 0;
    font-size: var(--fs-md);
    font-weight: 400;
    color: var(--muted);
    line-height: 1.6;
  }

  .link-list li {
    padding: 9px 0;
    border-bottom: 1px dashed #e9e9e2;
    font-size: var(--fs-md);
    font-weight: 400;
  }

  .link-list a {
    color: var(--text);
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .link-list a:hover {
    color: color-mix(in srgb, var(--text) 82%, var(--accent));
  }

  .carousel {
    margin-top: 16px;
  }

  .carousel-controls {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-bottom: 10px;
  }

  .carousel-button {
    border: 1px solid var(--line);
    background: var(--bg-soft);
    color: #60605c;
    width: 30px;
    height: 24px;
    line-height: 1;
    font: inherit;
    font-size: var(--fs-md);
    cursor: pointer;
  }

  .carousel-button:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--line) 65%, var(--accent));
  }

  .carousel-track {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .example-card {
    min-width: 100%;
    scroll-snap-align: start;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg-soft) 84%, #ffffff);
    padding: 14px;
  }

  .example-title {
    margin: 0;
    font-size: var(--fs-lg);
    font-weight: 500;
  }

  .example-summary {
    margin: 6px 0 0;
    color: #555550;
    font-size: var(--fs-md);
  }

  .example-preview {
    margin-top: 10px;
    border: 1px dashed color-mix(in srgb, var(--line) 82%, #c2c4ce);
    background: color-mix(in srgb, #ffffff 60%, var(--bg-soft));
    padding: 10px;
    min-height: 138px;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 8px;
  }

  .example-image-placeholder {
    margin: 0;
    color: #5d5d58;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .example-image-path {
    margin: 0;
    color: #6c6c67;
    font-size: var(--fs-xs);
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 10px;
  }

  .carousel-dot {
    width: 16px;
    height: 5px;
    border: 0;
    padding: 0;
    background: #d5d5ce;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .carousel-dot-fill {
    position: absolute;
    inset: 0;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
  }

  .carousel-dot.is-active .carousel-dot-fill {
    animation: dot-fill 5000ms linear forwards;
  }

  @keyframes dot-fill {
    to {
      transform: scaleX(1);
    }
  }

  .video-column {
    position: sticky;
    top: 68px;
    align-self: flex-start;
    flex: 0 0 320px;
    width: 320px;
    padding-top: 0;
  }

  .video-frame {
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg-soft) 90%, #ffffff);
    padding: 8px;
  }

  .product-demo {
    position: relative;
  }

  .product-demo-input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .product-demo-tabs {
    display: flex;
    gap: 6px;
    margin-bottom: 8px;
  }

  .product-demo-tabs label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 5px 9px;
    border: 1px solid color-mix(in srgb, var(--line) 84%, #c8cad4);
    background: rgba(255, 255, 255, 0.88);
    color: #66665f;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  #product-demo-capture:checked ~ .product-demo-tabs label[for="product-demo-capture"],
  #product-demo-rollover:checked ~ .product-demo-tabs label[for="product-demo-rollover"],
  #product-demo-recurring:checked ~ .product-demo-tabs label[for="product-demo-recurring"] {
    border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
    background: color-mix(in srgb, var(--accent) 10%, #ffffff);
    color: var(--accent);
  }

  .product-demo-window {
    position: relative;
    display: block;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 9 / 16;
    border: 1px dashed color-mix(in srgb, var(--line) 82%, #bfc2ce);
    background:
      radial-gradient(circle at bottom right, rgba(201, 211, 255, 0.65), transparent 28%),
      linear-gradient(180deg, #f7f7f2 0%, #efeee7 100%);
    overflow: hidden;
  }

  .product-demo-titlebar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 16px 10px;
  }

  .product-demo-dots {
    display: flex;
    gap: 7px;
  }

  .product-demo-dots span {
    width: 11px;
    height: 11px;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .product-demo-dots span:nth-child(1) {
    background: #ff6259;
  }

  .product-demo-dots span:nth-child(2) {
    background: #ffbd44;
  }

  .product-demo-dots span:nth-child(3) {
    background: #28c840;
  }

  .product-demo-pin {
    width: 16px;
    height: 16px;
    color: #a0a7b2;
  }

  .product-demo-panel {
    position: absolute;
    inset: 44px 14px 14px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(8px);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  #product-demo-capture:checked ~ .product-demo-window .product-demo-panel-capture,
  #product-demo-rollover:checked ~ .product-demo-window .product-demo-panel-rollover,
  #product-demo-recurring:checked ~ .product-demo-window .product-demo-panel-recurring {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .product-demo-note {
    height: 100%;
    padding: 18px 18px 20px;
    background: rgba(255, 255, 255, 0.84);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.95) inset,
      0 24px 48px rgba(44, 49, 63, 0.08);
    backdrop-filter: blur(8px);
  }

  .product-demo-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
  }

  .product-demo-date {
    margin: 0;
    font-family: "Instrument Serif", Georgia, serif;
    font-size: 22px;
    font-style: italic;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #1f2937;
  }

  .product-demo-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 11px 3px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-demo-pill-today {
    background: linear-gradient(to bottom, #4b5563, #1f2937);
    color: #ffffff;
  }

  .product-demo-city {
    color: #9ca3af;
    font-size: 13px;
  }

  .product-demo-body {
    display: grid;
    gap: 8px;
    margin-bottom: 18px;
    color: #1f2937;
    font-size: 14px;
    line-height: 1.35;
  }

  .product-demo-body p {
    margin: 0;
  }

  .product-demo-body a {
    color: #3b82f6;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.12em;
    overflow-wrap: anywhere;
  }

  .product-demo-status {
    margin-bottom: 14px;
    padding: 9px 11px;
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    background: color-mix(in srgb, var(--accent) 8%, #ffffff);
    color: #334155;
    font-size: 12px;
    font-weight: 500;
  }

  .product-demo-rollover-cards {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20px minmax(0, 1fr);
    gap: 8px;
