---
import { getCollection, } from "astro:content";

const capabilities = [
  {
    title: "Daily notes in one timeline",
    description: "Review older notes in a continuous feed instead of bouncing through tabs and old files.",
    visual: "timeline",
  },
  {
    title: "Unfinished tasks roll forward",
    description: "If a task is still open when the date changes, Philo brings it into today automatically.",
    visual: "rollover",
  },
  {
    title: "Recurring work comes back on its own",
    description: "Daily and scheduled tasks can return automatically, so you do not have to rebuild the same plan every morning.",
    visual: "recurring",
  },
  {
    title: "Markdown, not lock-in",
    description: "Keep your journal as plain files on disk and use your existing Obsidian vault if you want.",
    visual: "markdown",
  },
  {
    title: "Free and open source",
    description: "Philo is meant to augment your vault, not turn your daily notes into another subscription silo.",
    visual: "open-source",
  },
];

const examples = [
  {
    title: "Habit tracker",
    summary: "Track streaks and daily completion without leaving your note.",
    imagePath: "/examples/habit-tracker.png",
  },
  {
    title: "World clock",
    summary: "See your team time zones while planning tomorrow.",
    imagePath: "/examples/world-clock.png",
  },
  {
    title: "Calorie counter",
    summary: "Quick meal log with totals inline in the journal.",
    imagePath: "/examples/calorie-counter.png",
  },
  {
    title: "Countdown board",
    summary: "Keep launches and deadlines visible at a glance.",
    imagePath: "/examples/countdown-board.png",
  },
  {
    title: "Mood chart",
    summary: "Simple emotional trendline over the week.",
    imagePath: "/examples/mood-chart.png",
  },
  {
    title: "Meeting prep checklist",
    summary: "Turn rough notes into ready talking points.",
    imagePath: "/examples/meeting-prep-checklist.png",
  },
];

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Philo | Daily notes that carry unfinished work forward</title>
    <meta
      name="description"
      content="Open source, local-first daily notes app that keeps markdown in your Obsidian vault and rolls unfinished tasks into today automatically."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient"></div>
    <div class="page-layout">
      <main class="shell">
        <header class="enter" style="--delay: 0ms;">
          <div class="brand-row">
            <p class="brand">Philo <span class="brand-beta">beta</span></p>
          </div>
        </header>

        <section class="hero enter" style="--delay: 70ms;">
          <h1>Daily notes that carry unfinished work forward.</h1>
          <p class="lede">
            Philo started with one problem: daily notes are a great place to think, but unfinished
            tasks get buried in yesterday&apos;s file. It keeps your journal as markdown in your
            Obsidian vault, shows notes in a timeline, and rolls open tasks into today
            automatically.
          </p>
          <p class="hero-note">
            It is built first for people who already live in daily notes and want a calmer planning
            loop, not a bigger system to manage.
          </p>
          <div class="download-split" data-download>
            <a class="download-button" data-download-primary href="https://github.com/ComputelessComputer/philo/releases/latest">
              Download for macOS
            </a><button type="button" class="download-chevron" data-download-toggle aria-label="Other platforms"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg></button>
            <div class="download-menu" data-download-menu>
              <a data-download-macos href="https://github.com/ComputelessComputer/philo/releases/latest">macOS</a>
              <a data-download-windows href="https://github.com/ComputelessComputer/philo/releases/latest">Windows</a>
              <a data-download-linux href="https://github.com/ComputelessComputer/philo/releases/latest">Linux</a>
            </div>
          </div>
          <div class="video-mobile">
            <div class="video-frame">
              <video
                class="product-video"
                controls
                muted
                loop
                playsinline
                preload="metadata"
                poster="/philo-video-poster.svg"
              >
                <source src="/philo-demo.mp4" type="video/mp4" />
              </video>
            </div>
          </div>
        </section>

        <section class="panel enter" style="--delay: 140ms;">
          <h2>Why Philo exists</h2>
          <ul class="detail-list">
            {
              capabilities.map((item,) => (
                <li class="detail-item">
                  <div class="detail-copy">
                    <p class="item-title">{item.title}</p>
                    <p class="item-copy">{item.description}</p>
                  </div>
                  <div class={`detail-visual detail-visual-${item.visual}`} aria-hidden="true">
                    {
                      item.visual === "timeline" && (
                        <div class="mini-stack">
                          <span class="mini-sidebar"></span>
                          <div class="mini-stack-cards">
                            <span class="mini-card-line mini-card-line-short"></span>
                            <span class="mini-card-line"></span>
                            <span class="mini-card-line mini-card-line-accent"></span>
                          </div>
                        </div>
                      )
                    }
                    {
                      item.visual === "rollover" && (
                        <div class="mini-transfer">
                          <div class="mini-column">
                            <span class="mini-label"></span>
                            <span class="mini-chip mini-chip-muted"></span>
                            <span class="mini-chip"></span>
                          </div>
                          <span class="mini-arrow"></span>
                          <div class="mini-column mini-column-target">
                            <span class="mini-label"></span>
                            <span class="mini-chip mini-chip-accent"></span>
                            <span class="mini-chip"></span>
                          </div>
                        </div>
                      )
                    }
                    {
                      item.visual === "recurring" && (
                        <div class="mini-repeat">
                          <div class="mini-repeat-row">
                            <span class="mini-tag"></span>
                            <span class="mini-chip mini-chip-accent"></span>
                          </div>
                          <div class="mini-repeat-row">
                            <span class="mini-tag"></span>
                            <span class="mini-chip"></span>
                          </div>
                          <div class="mini-repeat-row">
                            <span class="mini-tag"></span>
                            <span class="mini-chip"></span>
                          </div>
                        </div>
                      )
                    }
                    {
                      item.visual === "markdown" && (
                        <div class="mini-files">
                          <div class="mini-tree">
                            <span></span>
                            <span></span>
                            <span class="is-current"></span>
                          </div>
                          <div class="mini-doc">
                            <span class="mini-doc-line mini-card-line-short"></span>
                            <span class="mini-doc-line"></span>
                            <span class="mini-doc-line"></span>
                          </div>
                        </div>
                      )
                    }
                    {
                      item.visual === "open-source" && (
                        <div class="mini-repo">
                          <span class="mini-repo-title"></span>
                          <div class="mini-repo-row">
                            <span class="mini-pill"></span>
                            <span class="mini-pill"></span>
                          </div>
                          <div class="mini-repo-row">
                            <span class="mini-pill mini-pill-wide"></span>
                            <span class="mini-pill"></span>
                          </div>
                        </div>
                      )
                    }
                  </div>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="panel enter" style="--delay: 210ms;">
          <h2>Extra utilities, if you want them</h2>
          <p class="item-copy">
            The core product is still the daily note. Widgets, AI help, and computer-use workflows
            are add-ons for the moments when plain text is not enough.
          </p>
          <div class="carousel" data-carousel>
            <div class="carousel-controls">
              <button type="button" class="carousel-button" data-carousel-prev aria-label="Previous example">←</button>
              <button type="button" class="carousel-button" data-carousel-next aria-label="Next example">→</button>
            </div>
            <div class="carousel-track" data-carousel-track>
              {
                examples.map((item,) => (
                  <article class="example-card">
                    <p class="example-title">{item.title}</p>
                    <p class="example-summary">{item.summary}</p>
                    <div class="example-preview" role="img" aria-label={`${item.title} image placeholder`}>
                      <p class="example-image-placeholder">Add image later</p>
                      <p class="example-image-path">{item.imagePath}</p>
                    </div>
                  </article>
                ))
              }
            </div>
            <div class="carousel-dots">
              {
                examples.map((item, index,) => (
                  <button
                    type="button"
                    class={`carousel-dot ${index === 0 ? "is-active" : ""}`}
                    data-carousel-dot
                    data-index={index}
                    aria-label={`Go to ${item.title}`}
                    aria-current={index === 0 ? "true" : "false"}
                  ><span class="carousel-dot-fill"></span></button>
                ))
              }
            </div>
          </div>
        </section>

        <section class="panel enter" style="--delay: 280ms;">
          <h2>Notes from the team</h2>
          <ul class="link-list">
            {
              posts.map((post,) => (
                <li>
                  <a href={`/blog/${post.slug}`}>
                    {post.data.title}
                    <span>→</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="panel enter" style="--delay: 350ms;">
          <h2>Built to sit beside your vault, not replace it</h2>
          <p class="item-copy">
            Philo is open source and free forever. Your notes stay as markdown files on disk, and
            the app is meant to make daily notes lighter, not trap them in a new format or workflow.
          </p>
        </section>

        <footer class="enter" style="--delay: 420ms;">
          <nav>
            <a href="https://github.com/ComputelessComputer/philo">GitHub</a>
            <a href="/blog">Blog</a>
            <a href="/privacy">Privacy</a>
            <a href="/terms">Terms</a>
            <a href="mailto:john@hyprnote.com">Email</a>
          </nav>
        </footer>
      </main>

      <aside class="video-column enter" style="--delay: 120ms;">
        <div class="video-frame">
          <video
            class="product-video"
            controls
            muted
            loop
            playsinline
            preload="metadata"
            poster="/philo-video-poster.svg"
          >
            <source src="/philo-demo.mp4" type="video/mp4" />
          </video>
        </div>
        <p class="video-note">Place `philo-demo.mp4` in `apps/landing/public/` to use your own demo.</p>
      </aside>
    </div>
  </body>
</html>

<script is:inline>
  (async () => {
    const REPO = "ComputelessComputer/philo";
    const FALLBACK = `https://github.com/${REPO}/releases/latest`;
    const primary = document.querySelector("[data-download-primary]",);
    const toggle = document.querySelector("[data-download-toggle]",);
    const menu = document.querySelector("[data-download-menu]",);
    const macLink = document.querySelector("[data-download-macos]",);
    const winLink = document.querySelector("[data-download-windows]",);
    const linuxLink = document.querySelector("[data-download-linux]",);

    toggle?.addEventListener("click", (e,) => {
      e.stopPropagation();
      menu?.classList.toggle("is-open",);
    },);

    document.addEventListener("click", () => {
      menu?.classList.remove("is-open",);
    },);

    try {
      const res = await fetch(`https://api.github.com/repos/${REPO}/releases/latest`,);
      if (!res.ok) throw new Error();
      const data = await res.json();
      const assets = data.assets ?? [];

      const find = (/** @type {RegExp} */ re,) => assets.find((a,) => re.test(a.name,),)?.browser_download_url;

      const urls = {
        macos: find(/\.dmg$/,) ?? FALLBACK,
        windows: find(/\.exe$/,) ?? FALLBACK,
        linux: find(/\.AppImage$/,) ?? FALLBACK,
      };

      if (macLink) macLink.href = urls.macos;
      if (winLink) winLink.href = urls.windows;
      if (linuxLink) linuxLink.href = urls.linux;

      const ua = navigator.userAgent.toLowerCase();
      let os = "macos";
      if (ua.includes("win",)) os = "windows";
      else if (ua.includes("linux",)) os = "linux";

      const labels = { macos: "Download for macOS", windows: "Download for Windows", linux: "Download for Linux" };
      if (primary) {
        primary.href = urls[os];
primary.firstChild.textContent = labels[os];
      }

      const currentLink = { macos: macLink, windows: winLink, linux: linuxLink }[os];
      if (currentLink) currentLink.classList.add("is-current",);
    } catch {
      // keep fallback links
    }
  })();

  const carousel = document.querySelector("[data-carousel]",);
  if (carousel) {
    const track = carousel.querySelector("[data-carousel-track]",);
    const prev = carousel.querySelector("[data-carousel-prev]",);
    const next = carousel.querySelector("[data-carousel-next]",);
    const dots = Array.from(carousel.querySelectorAll("[data-carousel-dot]",),);
    const total = track?.children.length ?? 0;
    const DURATION = 5000;
    let ticking = false;
    let timer = null;

    const getIndex = () => {
      if (!track) {
        return 0;
      }
      return Math.round(track.scrollLeft / track.clientWidth,);
    };

    const goTo = (index,) => {
      if (!track || total === 0) {
        return;
      }
      const nextIndex = (index + total) % total;
      track.scrollTo({
        left: nextIndex * track.clientWidth,
        behavior: "smooth",
      },);
    };

    const restartTimer = () => {
      clearTimeout(timer,);
      for (const dot of dots) {
        const fill = dot.querySelector(".carousel-dot-fill",);
        if (!fill) continue;
        fill.style.animation = "none";
        void fill.offsetWidth;
        fill.style.animation = "";
      }
      setActiveDot();
      timer = setTimeout(() => {
        goTo(getIndex() + 1,);
      }, DURATION,);
    };

    const setActiveDot = () => {
      const index = getIndex();
      for (const [dotIndex, dot] of dots.entries()) {
        const active = dotIndex === index;
        dot.classList.toggle("is-active", active,);
        dot.setAttribute("aria-current", active ? "true" : "false",);
        const fill = dot.querySelector(".carousel-dot-fill",);
        if (fill) {
          fill.style.animationDuration = `${DURATION}ms`;
        }
      }
    };

    prev?.addEventListener("click", () => { goTo(getIndex() - 1,); restartTimer(); },);
    next?.addEventListener("click", () => { goTo(getIndex() + 1,); restartTimer(); },);

    for (const dot of dots) {
      dot.addEventListener("click", () => {
        const index = Number(dot.getAttribute("data-index",) ?? "0",);
        goTo(index,);
        restartTimer();
      },);
    }

    track?.addEventListener("scroll", () => {
      if (ticking) {
        return;
      }
      ticking = true;
      window.requestAnimationFrame(() => {
        setActiveDot();
        ticking = false;
      },);
    },);

    setActiveDot();
    restartTimer();
    window.addEventListener("resize", setActiveDot,);
  }

</script>

<style>
  :root {
    --bg: #f4f4f1;
    --bg-soft: #f8f8f6;
    --line: #e2e2db;
    --text: #252525;
    --muted: #646460;
    --accent: #5f70d8;
    --fs-xs: 11px;
    --fs-sm: 12px;
    --fs-md: 13px;
    --fs-lg: 14px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-weight: 400;
    font-size: var(--fs-md);
    line-height: 1.6;
    background: linear-gradient(150deg, #f6f6f4 0%, #efefeb 100%);
    color: var(--text);
    position: relative;
  }

  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 5% 8%, #ffffff 0%, transparent 32%),
      radial-gradient(circle at 92% 92%, #e8ebff 0%, transparent 38%);
    opacity: 0.8;
  }

  .page-layout {
    position: relative;
    width: min(100%, 1160px);
    margin: 0 auto;
    padding: 0 24px;
    min-height: 100vh;
    display: flex;
    align-items: flex-start;
    gap: 34px;
  }

  .shell {
    position: relative;
    width: 100%;
    max-width: 720px;
    flex: 1 1 auto;
    padding: 68px 0 88px;
  }

  .brand-row {
    margin-bottom: 22px;
  }

  .brand {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .hero {
    position: relative;
    z-index: 1;
  }

  .hero h1 {
    margin: 0;
    font-size: var(--fs-lg);
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: 0.01em;
  }

  .lede {
    margin-top: 18px;
    max-width: 56ch;
    font-size: var(--fs-md);
    line-height: 1.6;
    color: #3f3f3d;
  }

  .hero-note {
    margin: 12px 0 0;
    max-width: 56ch;
    color: var(--muted);
    font-size: var(--fs-sm);
  }

  .download-split {
    position: relative;
    display: inline-flex;
    margin-top: 14px;
  }

  .download-button {
    color: var(--accent);
    font-family: inherit;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    background: color-mix(in srgb, var(--accent) 8%, #ffffff);
    padding: 8px 10px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .brand-beta {
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    background: color-mix(in srgb, var(--accent) 12%, #ffffff);
    color: var(--accent);
    padding: 2px 5px;
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1;
    vertical-align: middle;
    position: relative;
    top: -1px;
  }

  .download-button:hover {
    border-color: color-mix(in srgb, var(--accent) 44%, var(--line));
    background: color-mix(in srgb, var(--accent) 14%, #ffffff);
  }

  .download-chevron {
    font-family: inherit;
    font-size: var(--fs-sm);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    border-left: 0;
    background: color-mix(in srgb, var(--accent) 8%, #ffffff);
    padding: 0 8px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
  }

  .download-chevron:hover {
    border-color: color-mix(in srgb, var(--accent) 44%, var(--line));
    background: color-mix(in srgb, var(--accent) 14%, #ffffff);
  }

  .download-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 4px;
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    background: #ffffff;
    z-index: 10;
  }

  .download-menu.is-open {
    display: flex;
    flex-direction: column;
  }

  .download-menu a,
  .download-menu a:visited {
    padding: 8px 10px;
    color: var(--text);
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .download-menu a:hover {
    background: color-mix(in srgb, var(--accent) 8%, #ffffff);
    color: var(--accent);
  }

  .download-menu a.is-current {
    display: none;
  }

  .video-mobile {
    display: none;
    margin-top: 18px;
  }

  .panel {
    margin-top: 46px;
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }

  h2 {
    margin: 0;
    color: #3f3f3d;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .detail-list,
  .link-list {
    list-style: none;
    padding: 0;
    margin: 16px 0 0;
  }

  .detail-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .detail-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 16px;
    align-items: start;
  }

  .detail-visual {
    border: 1px dashed color-mix(in srgb, var(--line) 82%, #bfc2ce);
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.9) 0%, transparent 42%),
      color-mix(in srgb, var(--bg-soft) 90%, #ffffff);
    min-height: 92px;
    padding: 10px;
    overflow: hidden;
  }

  .mini-stack,
  .mini-transfer,
  .mini-repeat,
  .mini-files,
  .mini-repo {
    width: 100%;
    height: 100%;
  }

  .mini-stack {
    display: grid;
    grid-template-columns: 14px minmax(0, 1fr);
    gap: 8px;
    align-items: stretch;
  }

  .mini-sidebar {
    display: block;
    border-right: 1px solid color-mix(in srgb, var(--line) 84%, #c7cad5);
    background:
      linear-gradient(
        180deg,
        transparent 0 10%,
        color-mix(in srgb, var(--accent) 14%, #ffffff) 10% 28%,
        transparent 28% 42%,
        rgba(95, 95, 90, 0.08) 42% 58%,
        transparent 58% 72%,
        rgba(95, 95, 90, 0.08) 72% 88%,
        transparent 88% 100%
      );
  }

  .mini-stack-cards,
  .mini-column,
  .mini-doc,
  .mini-repo {
    display: grid;
    gap: 6px;
  }

  .mini-card-line,
  .mini-doc-line,
  .mini-pill,
  .mini-label,
  .mini-tag {
    display: block;
    height: 8px;
    border: 1px solid color-mix(in srgb, var(--line) 80%, #d1d4de);
    background: rgba(255, 255, 255, 0.92);
  }

  .mini-card-line-short {
    width: 54%;
  }

  .mini-card-line-accent,
  .mini-chip-accent,
  .mini-tree .is-current {
    border-color: color-mix(in srgb, var(--accent) 34%, var(--line));
    background: color-mix(in srgb, var(--accent) 12%, #ffffff);
  }

  .mini-transfer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 18px minmax(0, 1fr);
    gap: 8px;
    align-items: center;
  }

  .mini-column {
    border: 1px solid color-mix(in srgb, var(--line) 80%, #d3d6df);
    background: rgba(255, 255, 255, 0.86);
    padding: 6px;
  }

  .mini-column-target {
    border-color: color-mix(in srgb, var(--accent) 28%, var(--line));
  }

  .mini-chip {
