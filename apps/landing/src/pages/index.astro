---
import { getCollection, } from "astro:content";

const capabilities = [
  {
    title: "Journal in a timeline",
    description: "Tomorrow, today, and past notes stay in one continuous scroll.",
    placeholder: "replace with timeline screenshot",
  },
  {
    title: "Tasks that carry forward",
    description: "Unchecked tasks automatically roll into today until you finish them.",
    placeholder: "replace with task rollover screenshot",
  },
  {
    title: "Recurring tags",
    description: "Use #daily, #weekly, or custom intervals and tasks reappear on schedule.",
    placeholder: "replace with recurring tags screenshot",
  },
  {
    title: "Inline AI widgets",
    description: "Press Cmd+Enter to generate mini-apps directly inside your notes.",
    placeholder: "replace with widget generation screenshot",
  },
];

const examples = [
  {
    title: "Habit tracker",
    summary: "Track streaks and daily completion without leaving your note.",
    imagePath: "/examples/habit-tracker.png",
  },
  {
    title: "World clock",
    summary: "See your team time zones while planning tomorrow.",
    imagePath: "/examples/world-clock.png",
  },
  {
    title: "Calorie counter",
    summary: "Quick meal log with totals inline in the journal.",
    imagePath: "/examples/calorie-counter.png",
  },
  {
    title: "Countdown board",
    summary: "Keep launches and deadlines visible at a glance.",
    imagePath: "/examples/countdown-board.png",
  },
  {
    title: "Mood chart",
    summary: "Simple emotional trendline over the week.",
    imagePath: "/examples/mood-chart.png",
  },
  {
    title: "Meeting prep checklist",
    summary: "Turn rough notes into ready talking points.",
    imagePath: "/examples/meeting-prep-checklist.png",
  },
];

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Philo | A daily journaling app that builds things for you</title>
    <meta
      name="description"
      content="Write daily notes, carry tasks forward automatically, and generate custom mini-apps inline."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="ambient"></div>
    <div class="page-layout">
      <main class="shell">
        <header class="enter" style="--delay: 0ms;">
          <div class="brand-row">
            <p class="brand">Philo</p>
          </div>
        </header>

        <section class="hero enter" style="--delay: 70ms;">
          <h1>A daily journal that builds things for you.</h1>
          <p class="lede">
            Capture notes. Track tasks that roll forward. Generate tiny tools in place when you
            need them.
          </p>
          <a class="download-button" href="https://github.com/ComputelessComputer/philo/releases/latest">
            Download for macOS
            <span class="download-beta">beta</span>
            <span aria-hidden="true">→</span>
          </a>
          <div class="video-mobile">
            <div class="video-frame">
              <video
                class="product-video"
                controls
                muted
                loop
                playsinline
                preload="metadata"
                poster="/philo-video-poster.svg"
              >
                <source src="/philo-demo.mp4" type="video/mp4" />
              </video>
            </div>
          </div>
        </section>

        <section class="panel enter" style="--delay: 140ms;">
          <h2>Core flow</h2>
          <ul class="detail-list">
            {
              capabilities.map((item,) => (
                <li class="detail-item">
                  <div class="detail-copy">
                    <p class="item-title">{item.title}</p>
                    <p class="item-copy">{item.description}</p>
                  </div>
                  <div class="detail-placeholder" role="img" aria-label={`${item.title} image placeholder`}>
                    <span>{item.placeholder}</span>
                  </div>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="panel enter" style="--delay: 210ms;">
          <h2>Things people build in Philo</h2>
          <div class="carousel" data-carousel>
            <div class="carousel-controls">
              <button type="button" class="carousel-button" data-carousel-prev aria-label="Previous example">←</button>
              <button type="button" class="carousel-button" data-carousel-next aria-label="Next example">→</button>
            </div>
            <div class="carousel-track" data-carousel-track>
              {
                examples.map((item,) => (
                  <article class="example-card">
                    <p class="example-title">{item.title}</p>
                    <p class="example-summary">{item.summary}</p>
                    <div class="example-preview" role="img" aria-label={`${item.title} image placeholder`}>
                      <p class="example-image-placeholder">Add image later</p>
                      <p class="example-image-path">{item.imagePath}</p>
                    </div>
                  </article>
                ))
              }
            </div>
            <div class="carousel-dots">
              {
                examples.map((item, index,) => (
                  <button
                    type="button"
                    class={`carousel-dot ${index === 0 ? "is-active" : ""}`}
                    data-carousel-dot
                    data-index={index}
                    aria-label={`Go to ${item.title}`}
                    aria-current={index === 0 ? "true" : "false"}
                  ></button>
                ))
              }
            </div>
          </div>
        </section>

        <section class="panel enter" style="--delay: 280ms;">
          <h2>Notes from the team</h2>
          <ul class="link-list">
            {
              posts.map((post,) => (
                <li>
                  <a href={`/blog/${post.slug}`}>
                    {post.data.title}
                    <span>→</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="panel enter" style="--delay: 350ms;">
          <h2>Philo runs local-first</h2>
          <p class="item-copy">
            Your journal lives on disk as markdown files. Keep your data close, move fast, and
            shape the app around your own workflow.
          </p>
        </section>

        <footer class="enter" style="--delay: 420ms;">
          <nav>
            <a href="https://github.com/ComputelessComputer/philo">GitHub</a>
            <a href="/blog">Blog</a>
            <a href="/docs">Docs</a>
            <a href="mailto:john@hyprnote.com">Email</a>
          </nav>
        </footer>
      </main>

      <aside class="video-column enter" style="--delay: 120ms;">
        <div class="video-frame">
          <video
            class="product-video"
            controls
            muted
            loop
            playsinline
            preload="metadata"
            poster="/philo-video-poster.svg"
          >
            <source src="/philo-demo.mp4" type="video/mp4" />
          </video>
        </div>
        <p class="video-note">Place `philo-demo.mp4` in `apps/landing/public/` to use your own demo.</p>
      </aside>
    </div>
  </body>
</html>

<script is:inline>
  const carousel = document.querySelector("[data-carousel]",);
  if (carousel) {
    const track = carousel.querySelector("[data-carousel-track]",);
    const prev = carousel.querySelector("[data-carousel-prev]",);
    const next = carousel.querySelector("[data-carousel-next]",);
    const dots = Array.from(carousel.querySelectorAll("[data-carousel-dot]",),);
    const total = track?.children.length ?? 0;
    let ticking = false;

    const getIndex = () => {
      if (!track) {
        return 0;
      }
      return Math.round(track.scrollLeft / track.clientWidth,);
    };

    const goTo = (index,) => {
      if (!track || total === 0) {
        return;
      }
      const nextIndex = (index + total) % total;
      track.scrollTo({
        left: nextIndex * track.clientWidth,
        behavior: "smooth",
      },);
    };

    const setActiveDot = () => {
      const index = getIndex();
      for (const [dotIndex, dot] of dots.entries()) {
        const active = dotIndex === index;
        dot.classList.toggle("is-active", active,);
        dot.setAttribute("aria-current", active ? "true" : "false",);
      }
    };

    prev?.addEventListener("click", () => goTo(getIndex() - 1,),);
    next?.addEventListener("click", () => goTo(getIndex() + 1,),);

    for (const dot of dots) {
      dot.addEventListener("click", () => {
        const index = Number(dot.getAttribute("data-index",) ?? "0",);
        goTo(index,);
      },);
    }

    track?.addEventListener("scroll", () => {
      if (ticking) {
        return;
      }
      ticking = true;
      window.requestAnimationFrame(() => {
        setActiveDot();
        ticking = false;
      },);
    },);

    setActiveDot();
    window.addEventListener("resize", setActiveDot,);
  }
</script>

<style>
  :root {
    --bg: #f4f4f1;
    --bg-soft: #f8f8f6;
    --line: #e2e2db;
    --text: #252525;
    --muted: #646460;
    --accent: #5f70d8;
    --fs-xs: 11px;
    --fs-sm: 12px;
    --fs-md: 13px;
    --fs-lg: 14px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    font-family: "IBM Plex Mono", "SFMono-Regular", Menlo, monospace;
    font-weight: 400;
    font-size: var(--fs-md);
    line-height: 1.6;
    background: linear-gradient(150deg, #f6f6f4 0%, #efefeb 100%);
    color: var(--text);
    position: relative;
  }

  .ambient {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 5% 8%, #ffffff 0%, transparent 32%),
      radial-gradient(circle at 92% 92%, #e8ebff 0%, transparent 38%);
    opacity: 0.8;
  }

  .page-layout {
    position: relative;
    width: min(100%, 1160px);
    margin: 0 auto;
    padding: 68px 24px 88px;
    display: grid;
    grid-template-columns: minmax(0, 720px) minmax(0, 320px);
    gap: 34px;
    align-items: start;
  }

  .shell {
    position: relative;
    width: 100%;
  }

  .brand-row {
    margin-bottom: 22px;
  }

  .brand {
    margin: 0;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.01em;
  }

  .hero h1 {
    margin: 0;
    font-size: var(--fs-lg);
    font-weight: 500;
    line-height: 1.6;
    letter-spacing: 0.01em;
  }

  .lede {
    margin-top: 18px;
    max-width: 56ch;
    font-size: var(--fs-md);
    line-height: 1.6;
    color: #3f3f3d;
  }

  .download-button {
    margin-top: 14px;
    color: var(--accent);
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid color-mix(in srgb, var(--accent) 26%, var(--line));
    background: color-mix(in srgb, var(--accent) 8%, #ffffff);
    padding: 8px 10px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .download-beta {
    border: 1px solid color-mix(in srgb, var(--accent) 30%, var(--line));
    background: color-mix(in srgb, var(--accent) 12%, #ffffff);
    padding: 2px 5px;
    font-size: var(--fs-xs);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .download-button:hover {
    border-color: color-mix(in srgb, var(--accent) 44%, var(--line));
    background: color-mix(in srgb, var(--accent) 14%, #ffffff);
  }

  .video-mobile {
    display: none;
    margin-top: 18px;
  }

  .panel {
    margin-top: 46px;
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }

  h2 {
    margin: 0;
    color: #3f3f3d;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .detail-list,
  .link-list {
    list-style: none;
    padding: 0;
    margin: 16px 0 0;
  }

  .detail-list {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .detail-item {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 16px;
    align-items: start;
  }

  .detail-placeholder {
    border: 1px dashed color-mix(in srgb, var(--line) 82%, #bfc2ce);
    background: color-mix(in srgb, var(--bg-soft) 90%, #ffffff);
    min-height: 92px;
    padding: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .detail-placeholder span {
    color: #74746f;
    font-size: var(--fs-xs);
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .item-title {
    margin: 0;
    font-size: var(--fs-lg);
    font-weight: 500;
  }

  .link-list span {
    color: var(--accent);
  }

  .item-copy {
    margin: 6px 0 0;
    font-size: var(--fs-md);
    font-weight: 400;
    color: var(--muted);
    line-height: 1.6;
  }

  .link-list li {
    padding: 9px 0;
    border-bottom: 1px dashed #e9e9e2;
    font-size: var(--fs-md);
    font-weight: 400;
  }

  .link-list a {
    color: var(--text);
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .link-list a:hover {
    color: color-mix(in srgb, var(--text) 82%, var(--accent));
  }

  .carousel {
    margin-top: 16px;
  }

  .carousel-controls {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-bottom: 10px;
  }

  .carousel-button {
    border: 1px solid var(--line);
    background: var(--bg-soft);
    color: #60605c;
    width: 30px;
    height: 24px;
    line-height: 1;
    font: inherit;
    font-size: var(--fs-md);
    cursor: pointer;
  }

  .carousel-button:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--line) 65%, var(--accent));
  }

  .carousel-track {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .example-card {
    min-width: 100%;
    scroll-snap-align: start;
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg-soft) 84%, #ffffff);
    padding: 14px;
  }

  .example-title {
    margin: 0;
    font-size: var(--fs-lg);
    font-weight: 500;
  }

  .example-summary {
    margin: 6px 0 0;
    color: #555550;
    font-size: var(--fs-md);
  }

  .example-preview {
    margin-top: 10px;
    border: 1px dashed color-mix(in srgb, var(--line) 82%, #c2c4ce);
    background: color-mix(in srgb, #ffffff 60%, var(--bg-soft));
    padding: 10px;
    min-height: 138px;
    display: grid;
    align-content: center;
    justify-items: center;
    gap: 8px;
  }

  .example-image-placeholder {
    margin: 0;
    color: #5d5d58;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .example-image-path {
    margin: 0;
    color: #6c6c67;
    font-size: var(--fs-xs);
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 10px;
  }

  .carousel-dot {
    width: 16px;
    height: 5px;
    border: 0;
    background: #d5d5ce;
    cursor: pointer;
  }

  .carousel-dot.is-active {
    background: var(--accent);
  }

  .video-column {
    position: sticky;
    top: 50vh;
    transform: translateY(-50%);
    padding-top: 0;
  }

  .video-frame {
    border: 1px solid var(--line);
    background: color-mix(in srgb, var(--bg-soft) 90%, #ffffff);
    padding: 8px;
  }

  .product-video {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    border: 1px dashed color-mix(in srgb, var(--line) 82%, #bfc2ce);
    background: #efefe9;
  }

  .video-column .product-video {
    aspect-ratio: 9 / 16;
  }

  .video-note {
    margin: 10px 0 0;
    color: #676762;
    font-size: var(--fs-xs);
  }

  footer {
    margin-top: 42px;
    border-top: 1px solid var(--line);
    padding-top: 24px;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  nav a {
    color: var(--accent);
    text-decoration: none;
    font-size: var(--fs-sm);
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  nav a:hover {
    text-decoration: underline;
  }

  .enter {
    opacity: 0;
    transform: translateY(14px);
    animation: rise 560ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--delay);
  }

  @keyframes rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 980px) {
    .page-layout {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .video-column {
      display: none;
    }

    .video-mobile {
      display: block;
    }

    .video-mobile .product-video {
      aspect-ratio: auto;
    }
  }

  @media (max-width: 720px) {
    .page-layout {
      padding: 42px 18px 62px;
    }

    .shell {
      width: 100%;
    }

    .brand {
      font-size: 15px;
    }

    .hero h1 {
      font-size: var(--fs-lg);
    }

    .link-list li {
      font-size: var(--fs-md);
    }

    .detail-item {
      grid-template-columns: 1fr;
    }
  }
</style>
