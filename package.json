{
  "name": "philo-workspace",
  "private": true,
  "version": "0.0.10",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @philo/desktop dev",
    "build": "pnpm --filter @philo/desktop build",
    "preview": "pnpm --filter @philo/desktop preview",
    "typecheck": "pnpm --filter @philo/desktop typecheck && pnpm --filter @philo/landing typecheck",
    "fmt": "dprint fmt",
    "fmt:check": "dprint check",
    "check": "pnpm run typecheck && pnpm run fmt",
    "tauri": "pnpm --filter @philo/desktop tauri"
  }
}
